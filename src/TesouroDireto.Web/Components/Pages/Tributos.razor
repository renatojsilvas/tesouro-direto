@page "/tributos"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Tributos</PageTitle>

<div class="page-header fade-in">
    <h1>Tributos</h1>
    <p class="subtitle">Gerencie configuracoes de impostos e taxas</p>
</div>

<div class="mb-3">
    <button id="novo-tributo" class="btn btn-primary" @onclick="MostrarFormCriacao">Novo Tributo</button>
</div>

@if (erro is not null)
{
    <div class="alert alert-danger alert-dismissible">
        @erro
        <button type="button" class="btn-close" @onclick="() => erro = null"></button>
    </div>
}

@if (sucesso is not null)
{
    <div class="alert alert-success alert-dismissible" data-testid="sucesso">
        @sucesso
        <button type="button" class="btn-close" @onclick="() => sucesso = null"></button>
    </div>
}

@if (mostrarForm)
{
    <div class="card mb-4" data-testid="form-tributo">
        <div class="card-body">
            <h5 class="card-title">@(editandoId is null ? "Novo Tributo" : "Editar Tributo")</h5>

            @if (editandoId is null)
            {
                <div class="row mb-3">
                    <div class="col-md-4">
                        <label for="nome" class="form-label">Nome</label>
                        <input id="nome" type="text" class="form-control" @bind="formNome" />
                    </div>
                    <div class="col-md-3">
                        <label for="baseCalculo" class="form-label">Base Cálculo</label>
                        <select id="baseCalculo" class="form-select" @bind="formBaseCalculo">
                            <option value="Rendimento">Rendimento</option>
                            <option value="PuBruto">PU Bruto</option>
                            <option value="ValorInvestido">Valor Investido</option>
                            <option value="ValorResgate">Valor Resgate</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label for="tipoCalculo" class="form-label">Tipo Cálculo</label>
                        <select id="tipoCalculo" class="form-select" @bind="formTipoCalculo">
                            <option value="FaixaPorDias">Faixa por Dias</option>
                            <option value="AliquotaFixa">Alíquota Fixa</option>
                            <option value="TabelaDiaria">Tabela Diária</option>
                        </select>
                    </div>
                </div>
                <div class="row mb-3">
                    <div class="col-md-2">
                        <label for="ordem" class="form-label">Ordem</label>
                        <input id="ordem" type="number" class="form-control" @bind="formOrdem" />
                    </div>
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input id="cumulativo" type="checkbox" class="form-check-input" @bind="formCumulativo" />
                            <label for="cumulativo" class="form-check-label">Cumulativo</label>
                        </div>
                    </div>
                </div>
            }

            @if (editandoId is not null)
            {
                <div class="row mb-3">
                    <div class="col-md-3 d-flex align-items-end">
                        <div class="form-check">
                            <input id="ativo" type="checkbox" class="form-check-input" @bind="formAtivo" />
                            <label for="ativo" class="form-check-label">Ativo</label>
                        </div>
                    </div>
                </div>
            }

            <h6>Faixas</h6>
            <table class="table table-sm mb-2">
                <thead>
                    <tr>
                        <th>Dias Mín</th>
                        <th>Dias Máx</th>
                        <th>Dia</th>
                        <th>Alíquota (%)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @for (var i = 0; i < formFaixas.Count; i++)
                    {
                        var idx = i;
                        <tr>
                            <td><input type="number" class="form-control form-control-sm" @bind="formFaixas[idx].DiasMin" /></td>
                            <td><input type="number" class="form-control form-control-sm" @bind="formFaixas[idx].DiasMax" /></td>
                            <td><input type="number" class="form-control form-control-sm" @bind="formFaixas[idx].Dia" /></td>
                            <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="formFaixas[idx].Aliquota" /></td>
                            <td><button class="btn btn-sm btn-outline-danger" @onclick="() => formFaixas.RemoveAt(idx)">X</button></td>
                        </tr>
                    }
                </tbody>
            </table>
            <button class="btn btn-sm btn-outline-secondary mb-3" data-testid="btn-adicionar-faixa" @onclick="() => formFaixas.Add(new FaixaForm())">+ Faixa</button>

            <div>
                <button class="btn btn-success me-2" data-testid="btn-salvar" @onclick="SalvarAsync" disabled="@salvando">
                    @if (salvando) { <span class="spinner-border spinner-border-sm me-1"></span> }
                    Salvar
                </button>
                <button class="btn btn-secondary" data-testid="btn-cancelar" @onclick="CancelarForm">Cancelar</button>
            </div>
        </div>
    </div>
}

@if (loading)
{
    <p><em>Carregando tributos...</em></p>
}
else if (tributos is { Count: > 0 })
{
    <table class="table table-striped table-hover" data-testid="tabela-tributos">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Base Cálculo</th>
                <th>Tipo Cálculo</th>
                <th class="text-center">Ordem</th>
                <th class="text-center">Cumulativo</th>
                <th class="text-center">Status</th>
                <th>Faixas</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tributo in tributos)
            {
                <tr>
                    <td>@tributo.Nome</td>
                    <td>@tributo.BaseCalculo</td>
                    <td>@tributo.TipoCalculo</td>
                    <td class="text-center">@tributo.Ordem</td>
                    <td class="text-center">@(tributo.Cumulativo ? "Sim" : "Não")</td>
                    <td class="text-center">
                        @if (tributo.Ativo)
                        {
                            <span class="badge bg-success">Ativo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inativo</span>
                        }
                    </td>
                    <td>
                        @foreach (var f in tributo.Faixas)
                        {
                            <small class="d-block">
                                @if (f.DiasMin.HasValue || f.DiasMax.HasValue)
                                {
                                    @($"{f.DiasMin ?? 0}-{f.DiasMax?.ToString() ?? "∞"}d → {f.Aliquota:N2}%")
                                }
                                else if (f.Dia.HasValue)
                                {
                                    @($"Dia {f.Dia} → {f.Aliquota:N2}%")
                                }
                                else
                                {
                                    @($"{f.Aliquota:N2}%")
                                }
                            </small>
                        }
                    </td>
                    <td>
                        <button class="btn btn-sm btn-outline-primary" data-testid="btn-editar" @onclick="() => MostrarFormEdicao(tributo)">Editar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else if (!loading)
{
    <p class="text-muted">Nenhum tributo cadastrado.</p>
}

@code {
    private List<TributoItem>? tributos;
    private bool loading = true;
    private bool salvando;
    private string? erro;
    private string? sucesso;
    private bool mostrarForm;

    // Form fields
    private Guid? editandoId;
    private string formNome = "";
    private string formBaseCalculo = "Rendimento";
    private string formTipoCalculo = "FaixaPorDias";
    private int formOrdem = 1;
    private bool formCumulativo;
    private bool formAtivo = true;
    private List<FaixaForm> formFaixas = [];

    protected override async Task OnInitializedAsync()
    {
        await CarregarAsync();
    }

    private async Task CarregarAsync()
    {
        loading = true;
        try
        {
            var client = HttpClientFactory.CreateClient("TesouroDiretoApi");
            tributos = await client.GetFromJsonAsync<List<TributoItem>>("configuracoes/tributos");
        }
        catch (Exception ex)
        {
            erro = $"Falha ao carregar tributos: {ex.Message}";
        }
        finally
        {
            loading = false;
        }
    }

    private void MostrarFormCriacao()
    {
        editandoId = null;
        formNome = "";
        formBaseCalculo = "Rendimento";
        formTipoCalculo = "FaixaPorDias";
        formOrdem = 1;
        formCumulativo = false;
        formFaixas = [new FaixaForm()];
        mostrarForm = true;
        erro = null;
        sucesso = null;
    }

    private void MostrarFormEdicao(TributoItem tributo)
    {
        editandoId = tributo.Id;
        formAtivo = tributo.Ativo;
        formFaixas = tributo.Faixas.Select(f => new FaixaForm
        {
            DiasMin = f.DiasMin,
            DiasMax = f.DiasMax,
            Dia = f.Dia,
            Aliquota = f.Aliquota
        }).ToList();
        mostrarForm = true;
        erro = null;
        sucesso = null;
    }

    private void CancelarForm()
    {
        mostrarForm = false;
    }

    private async Task SalvarAsync()
    {
        erro = null;
        sucesso = null;
        salvando = true;

        try
        {
            var client = HttpClientFactory.CreateClient("TesouroDiretoApi");
            var faixas = formFaixas.Select(f => new { f.DiasMin, f.DiasMax, f.Dia, f.Aliquota }).ToList();

            HttpResponseMessage response;

            if (editandoId is null)
            {
                var body = new
                {
                    nome = formNome,
                    baseCalculo = ParseEnum(formBaseCalculo),
                    tipoCalculo = ParseEnum(formTipoCalculo),
                    faixas,
                    ordem = formOrdem,
                    cumulativo = formCumulativo
                };
                response = await client.PostAsJsonAsync("configuracoes/tributos", body);
            }
            else
            {
                var body = new { ativo = formAtivo, faixas };
                response = await client.PutAsJsonAsync($"configuracoes/tributos/{editandoId}", body);
            }

            if (response.IsSuccessStatusCode)
            {
                sucesso = editandoId is null ? "Tributo criado." : "Tributo atualizado.";
                mostrarForm = false;
                await CarregarAsync();
            }
            else
            {
                var responseBody = await response.Content.ReadAsStringAsync();
                try
                {
                    var error = System.Text.Json.JsonSerializer.Deserialize<ApiError>(
                        responseBody, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    erro = error?.Description ?? $"Erro: HTTP {(int)response.StatusCode}";
                }
                catch
                {
                    erro = $"Erro: HTTP {(int)response.StatusCode}";
                }
            }
        }
        catch (Exception ex)
        {
            erro = $"Falha na comunicação: {ex.Message}";
        }
        finally
        {
            salvando = false;
        }
    }

    private static int ParseEnum(string value)
    {
        return value switch
        {
            "Rendimento" => 0,
            "PuBruto" => 1,
            "ValorInvestido" => 2,
            "ValorResgate" => 3,
            "FaixaPorDias" => 0,
            "AliquotaFixa" => 1,
            "TabelaDiaria" => 2,
            _ => 0
        };
    }

    private sealed class FaixaForm
    {
        public int? DiasMin { get; set; }
        public int? DiasMax { get; set; }
        public int? Dia { get; set; }
        public decimal Aliquota { get; set; }
    }

    private sealed record TributoItem(
        Guid Id, string Nome, string BaseCalculo, string TipoCalculo,
        List<FaixaItem> Faixas, bool Ativo, int Ordem, bool Cumulativo);

    private sealed record FaixaItem(int? DiasMin, int? DiasMax, int? Dia, decimal Aliquota);
    private sealed record ApiError(string Code, string Description);
}
