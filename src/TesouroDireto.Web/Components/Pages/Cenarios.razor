@page "/simulador/cenarios"
@rendermode InteractiveServer
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Cenários</PageTitle>

<h1>Simulador de Cenários</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card mb-4">
            <div class="card-body">
                <h5 class="card-title">Dados do Investimento</h5>

                <div class="mb-3">
                    <label for="titulo" class="form-label">Título</label>
                    @if (loadingTitulos)
                    {
                        <p><em>Carregando títulos...</em></p>
                    }
                    else
                    {
                        <select id="titulo" class="form-select" @bind="selectedTituloId">
                            <option value="">Selecione um título</option>
                            @if (titulos is not null)
                            {
                                @foreach (var titulo in titulos.Where(t => t.Indexador != "Prefixado"))
                                {
                                    <option value="@titulo.Id">@titulo.TipoTitulo - @titulo.DataVencimento</option>
                                }
                            }
                        </select>
                    }
                </div>

                <div class="row mb-3">
                    <div class="col">
                        <label for="valorInvestido" class="form-label">Valor Investido (R$)</label>
                        <input id="valorInvestido" type="number" class="form-control" step="0.01" @bind="valorInvestido" />
                    </div>
                    <div class="col">
                        <label for="dataCompra" class="form-label">Data de Compra</label>
                        <input id="dataCompra" type="date" class="form-control" @bind="dataCompra" />
                    </div>
                </div>

                <div class="mb-3">
                    <label for="taxaContratada" class="form-label">Taxa Contratada (% a.a.)</label>
                    <input id="taxaContratada" type="number" class="form-control" step="0.01" @bind="taxaContratada" />
                </div>

                <h6>Cenários de Projeção</h6>
                @for (var i = 0; i < cenarios.Count; i++)
                {
                    var idx = i;
                    <div class="row mb-2" data-testid="cenario">
                        <div class="col-5">
                            <input type="text" class="form-control form-control-sm" placeholder="Nome"
                                   @bind="cenarios[idx].Nome" />
                        </div>
                        <div class="col-4">
                            <div class="input-group input-group-sm">
                                <input type="number" class="form-control" step="0.01" placeholder="% a.a."
                                       @bind="cenarios[idx].Projecao" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-3">
                            @if (cenarios.Count > 1)
                            {
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => cenarios.RemoveAt(idx)">Remover</button>
                            }
                        </div>
                    </div>
                }

                <button id="adicionar-cenario" class="btn btn-sm btn-outline-secondary mb-3" @onclick="AdicionarCenario">+ Cenário</button>

                <div>
                    <button id="simular" class="btn btn-primary w-100" @onclick="SimularAsync" disabled="@simulando">
                        @if (simulando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        Comparar Cenários
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        @if (erro is not null)
        {
            <div class="alert alert-danger">@erro</div>
        }

        @if (resultados is { Count: > 0 })
        {
            <div data-testid="resultados">
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Comparação de Cenários</h5>
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th></th>
                                        @foreach (var r in resultados)
                                        {
                                            <th class="text-center">@r.Nome</th>
                                        }
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Valor Bruto</td>
                                        @foreach (var r in resultados)
                                        {
                                            <td class="text-end">@r.Resultado.ValorBruto.ToString("C2", Cultura)</td>
                                        }
                                    </tr>
                                    <tr>
                                        <td>Rendimento Bruto</td>
                                        @foreach (var r in resultados)
                                        {
                                            <td class="text-end text-success">@r.Resultado.RendimentoBruto.ToString("C2", Cultura)</td>
                                        }
                                    </tr>
                                    <tr>
                                        <td>Total Tributos</td>
                                        @foreach (var r in resultados)
                                        {
                                            <td class="text-end text-danger">@r.Resultado.TotalTributos.ToString("C2", Cultura)</td>
                                        }
                                    </tr>
                                    <tr class="fw-bold">
                                        <td>Valor Líquido</td>
                                        @foreach (var r in resultados)
                                        {
                                            <td class="text-end">@r.Resultado.ValorLiquido.ToString("C2", Cultura)</td>
                                        }
                                    </tr>
                                    <tr class="fw-bold">
                                        <td>Rendimento Líquido</td>
                                        @foreach (var r in resultados)
                                        {
                                            <td class="text-end text-success">@r.Resultado.RendimentoLiquido.ToString("C2", Cultura)</td>
                                        }
                                    </tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private static readonly System.Globalization.CultureInfo Cultura = new("pt-BR");

    private List<TituloItem>? titulos;
    private bool loadingTitulos = true;
    private bool simulando;
    private string? erro;
    private string selectedTituloId = "";
    private decimal valorInvestido;
    private DateTime dataCompra = DateTime.Today;
    private decimal taxaContratada;
    private List<CenarioForm> cenarios = [new("Otimista", 3), new("Base", 5), new("Pessimista", 7)];
    private List<CenarioResult>? resultados;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("TesouroDiretoApi");
            titulos = await client.GetFromJsonAsync<List<TituloItem>>("titulos?vencido=false");
        }
        catch
        {
            erro = "Falha ao carregar títulos.";
        }
        finally
        {
            loadingTitulos = false;
        }
    }

    private void AdicionarCenario()
    {
        cenarios.Add(new CenarioForm($"Cenário {cenarios.Count + 1}", 0));
    }

    private async Task SimularAsync()
    {
        erro = null;
        resultados = null;

        if (string.IsNullOrEmpty(selectedTituloId) || !Guid.TryParse(selectedTituloId, out var tituloGuid))
        {
            erro = "Selecione um título.";
            return;
        }

        if (valorInvestido <= 0)
        {
            erro = "Valor investido deve ser maior que zero.";
            return;
        }

        if (cenarios.Count == 0)
        {
            erro = "Adicione pelo menos um cenário.";
            return;
        }

        simulando = true;

        try
        {
            var client = HttpClientFactory.CreateClient("TesouroDiretoApi");
            var request = new
            {
                tituloId = tituloGuid,
                valorInvestido,
                dataCompra = DateOnly.FromDateTime(dataCompra),
                taxaContratada,
                cenarios = cenarios.Select(c => new { nome = c.Nome, projecaoAnual = c.Projecao }).ToList()
            };

            var response = await client.PostAsJsonAsync("simulador/cenarios", request);
            var responseBody = await response.Content.ReadAsStringAsync();

            if (response.IsSuccessStatusCode)
            {
                resultados = System.Text.Json.JsonSerializer.Deserialize<List<CenarioResult>>(
                    responseBody, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }
            else
            {
                try
                {
                    var error = System.Text.Json.JsonSerializer.Deserialize<ApiError>(
                        responseBody, new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                    erro = error?.Description ?? $"Erro: HTTP {(int)response.StatusCode}";
                }
                catch
                {
                    erro = $"Erro: HTTP {(int)response.StatusCode}";
                }
            }
        }
        catch (Exception ex)
        {
            erro = $"Falha na comunicação: {ex.Message}";
        }
        finally
        {
            simulando = false;
        }
    }

    private sealed class CenarioForm(string nome, decimal projecao)
    {
        public string Nome { get; set; } = nome;
        public decimal Projecao { get; set; } = projecao;
    }

    private sealed record TituloItem(Guid Id, string TipoTitulo, string DataVencimento, string Indexador);

    private sealed record CenarioResult(string Nome, SimResult Resultado);

    private sealed record SimResult(
        decimal ValorInvestido, decimal ValorBruto, decimal RendimentoBruto,
        decimal TotalTributos, decimal ValorLiquido, decimal RendimentoLiquido);

    private sealed record ApiError(string Code, string Description);
}
